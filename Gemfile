source 'https://rubygems.org'
gem 'github-pages', group: :jekyll_plugins

# Force the newest 4.0.x patch release: 4.0.4 removes the Ruby-2.x-era
# String#tainted? call that crashes rendering on Ruby 3.2+ (tainting was
# removed from Ruby entirely). jekyll 3.9 only requires "~> 4.0", so this
# stays within its supported range.
gem 'liquid', '~> 4.0', '>= 4.0.4'
